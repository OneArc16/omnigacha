generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RecommendationLevel {
  NO_RECOMENDADO
  SITUACIONAL
  RECOMENDADO
  MUY_RECOMENDADO
}

enum TagCategory {
  PRO
  CON
  ARCHETYPE
  ROLE
  CHARACTERISTIC
  SPECIAL
}

enum StatKey {
  HP
  ATK
  DEF
  SPEED
  CRIT_RATE
  CRIT_DAMAGE
  BREAK_EFFECT
  ENERGY_REGEN_RATE
  EFFECT_HIT_RATE
  EFFECT_RES
  ELEMENTAL_DMG_BONUS
}

enum TraceStatKey {
  HP_PERCENT
  ATK_PERCENT
  DEF_PERCENT
  SPEED_FLAT
  CRIT_RATE
  CRIT_DAMAGE
  BREAK_EFFECT
  ENERGY_REGEN_RATE
  EFFECT_HIT_RATE
  EFFECT_RES
  ELEMENTAL_DMG_BONUS
}

enum UserRole {
  USER
  ADMIN
}

enum CatalogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum RelicSetType {
  ARTIFACT
  ORNAMENT
}

enum MediaKind {
  SPLASH_ART
}

enum StorageDriver {
  LOCAL
  S3
}

model User {
  id              Int              @id @default(autoincrement())
  name            String
  email           String           @unique
  passwordHash    String
  role            UserRole         @default(USER)
  isActive        Boolean          @default(true)
  mustChangePassword Boolean        @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  userCharacters  UserCharacter[]
  recommendations Recommendation[]
  refreshTokens   RefreshToken[]
  simulations     Simulation[]
  createdMediaAssets MediaAsset[]
}

model Character {
  id             Int                @id @default(autoincrement())
  name           String             @unique
  slug           String             @unique
  element        String
  path           String
  role           String
  rarity         Int                @default(5)
  gameVersion    String             @default("3.8")
  status         CatalogStatus      @default(PUBLISHED)
  baseHp         Int                @default(0)
  baseAtk        Int
  baseDef        Int                @default(0)
  baseCritRate   Float              @default(0.05)
  baseCritDamage Float              @default(0.5)
  baseSpeed      Int
  splashArtAssetId Int?              @unique
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  aliases        CharacterAlias[]
  tags           CharacterTag[]
  traceStats     CharacterTraceStat[]
  userCharacters UserCharacter[]
  synergiesFrom  CharacterSynergy[] @relation("SynergyFrom")
  synergiesTo    CharacterSynergy[] @relation("SynergyTo")
  splashArtAsset MediaAsset?        @relation("CharacterSplashArt", fields: [splashArtAssetId], references: [id], onDelete: SetNull)

  @@index([status])
}

model CharacterAlias {
  id              Int       @id @default(autoincrement())
  characterId     Int
  alias           String
  normalizedAlias String    @unique
  locale          String?
  source          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, alias])
  @@index([characterId])
}

model TagDefinition {
  key                 String       @id
  displayLabel        String
  category            TagCategory
  internalDescription String?
  isActive            Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  characters          CharacterTag[]

  @@index([category])
}

model CharacterTag {
  characterId Int
  tagKey      String
  createdAt   DateTime      @default(now())
  character   Character     @relation(fields: [characterId], references: [id], onDelete: Cascade)
  tag         TagDefinition @relation(fields: [tagKey], references: [key], onDelete: Cascade)

  @@id([characterId, tagKey])
  @@index([tagKey])
}

model CharacterTraceStat {
  id          Int      @id @default(autoincrement())
  characterId Int
  statKey     TraceStatKey
  value       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, statKey])
  @@index([statKey])
}

model LightCone {
  id                Int             @id @default(autoincrement())
  name              String          @unique
  slug             String          @unique
  path              String
  rarity            Int
  effectDescription String?
  status           CatalogStatus   @default(PUBLISHED)
  splashArtAssetId  Int?            @unique
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  userCharacters    UserCharacter[]
  splashArtAsset    MediaAsset?     @relation("LightConeSplashArt", fields: [splashArtAssetId], references: [id], onDelete: SetNull)

  @@index([path])
  @@index([status])
}

model CharacterSynergy {
  id                 Int    @id @default(autoincrement())
  sourceCharacterId  Int
  targetCharacterId  Int
  weight             Int
  note               String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  sourceCharacter Character @relation("SynergyFrom", fields: [sourceCharacterId], references: [id], onDelete: Cascade)
  targetCharacter Character @relation("SynergyTo", fields: [targetCharacterId], references: [id], onDelete: Cascade)

  @@unique([sourceCharacterId, targetCharacterId])
  @@index([sourceCharacterId])
  @@index([targetCharacterId])
}

model RelicSet {
  id              Int            @id @default(autoincrement())
  name            String         @unique
  slug            String         @unique
  type            RelicSetType
  rarity          Int
  twoPieceBonus   String
  fourPieceBonus  String?
  gameVersion     String?
  status          CatalogStatus  @default(DRAFT)
  splashArtAssetId Int?           @unique
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  splashArtAsset  MediaAsset?    @relation("RelicSetSplashArt", fields: [splashArtAssetId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([status])
}

model MediaAsset {
  id              Int            @id @default(autoincrement())
  kind            MediaKind
  storageDriver   StorageDriver  @default(LOCAL)
  storageKey      String         @unique
  publicUrl       String
  mimeType        String
  sizeBytes       Int
  width           Int?
  height          Int?
  checksum        String?
  createdByUserId Int
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  createdBy User @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  characterSplashArt Character? @relation("CharacterSplashArt")
  lightConeSplashArt LightCone? @relation("LightConeSplashArt")
  relicSetSplashArt RelicSet? @relation("RelicSetSplashArt")

  @@index([kind])
  @@index([createdByUserId])
}

model RefreshToken {
  id           Int    @id @default(autoincrement())
  userId       Int
  tokenHash    String    @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model UserCharacter {
  id               Int   @id @default(autoincrement())
  userId           Int
  characterId      Int
  lightConeId      Int?
  level            Int
  eidolon          Int
  lightConeName    String?
  lightConeLevel   Int?
  stats            Json?
  statSources      Json?
  hp               Int?
  atk              Int
  def              Int?
  critRate         Float
  critDamage       Float
  breakEffect      Float?
  energyRegenRate  Float?
  effectHitRate    Float?
  effectRes        Float?
  elementalDmgBonus Float?
  speed            Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Restrict)
  lightCone LightCone? @relation(fields: [lightConeId], references: [id], onDelete: SetNull)

  @@unique([userId, characterId])
  @@index([userId])
  @@index([characterId])
  @@index([lightConeId])
}

model Recommendation {
  id                 Int              @id @default(autoincrement())
  userId             Int
  targetCharacter    String
  score              Int
  level              RecommendationLevel
  explanation        String
  estimatedDeltaDmg  Float
  compatibleTeams    Int
  createdAt          DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([targetCharacter])
}

model Simulation {
  id             Int   @id @default(autoincrement())
  userId         Int
  label          String
  payload        Json
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
